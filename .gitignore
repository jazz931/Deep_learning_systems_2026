# =============================================================================
# PYTHON (из официального .gitignore deepface)
# =============================================================================
**/__pycache__/
**/.DS_Store
build/
dist/
Pipfile
Pipfile.lock
.mypy_cache/
*.pyc
**/.coverage
**/.coverage.*

# =============================================================================
# IDE / EDITORS
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~

# =============================================================================
# VIRTUAL ENVIRONMENTS
# =============================================================================
venv/
env/
.venv/
**/.env

# =============================================================================
# DEEPFACE-SPECIFIC (из официального)
# =============================================================================
deepface.egg-info/
tests/unit/dataset/*.pkl
tests/unit/*.ipynb
tests/unit/*.csv
benchmarks/results
benchmarks/outputs
benchmarks/dataset
benchmarks/lfwe
docker/weaviate_data

# =============================================================================
# МОИ ДОБАВЛЕНИЯ
# =============================================================================

# Веса моделей (скачаются автоматически, ~1 ГБ — не нужно в репозитории)
.deepface_weights/
.deepface/

# Результаты тестов (генерируются при запуске)
output/
*.json

# Логи и временные файлы
*.log
*.tmp
*.temp

# Docker (если не хочешь коммитить образы)
*.tar
*.tar.gz
